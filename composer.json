{
    "name": "graystack/laravel-ship24-api",
    "description": "Laravel package for the Ship24 shipment tracking API, built on Saloon 4",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "ship24", "tracking", "shipment", "parcel", "saloon"],
    "homepage": "https://github.com/GraystackIT/laravel-ship24-api",
    "authors": [
        {
            "name": "GraystackIT"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "saloonphp/saloon": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Graystack\\Ship24\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Graystack\\Ship24\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Graystack\\Ship24\\Ship24ServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
